    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "decision_type": {
      "title": "Decision Type",
      "type": "string"
    },
    "goals": {
      "items": {
        "type": "string"
      },
      "title": "Goals",
      "type": "array"
    },
    "fears": {
      "items": {
        "type": "string"
      },
      "title": "Fears",
      "type": "array"
    },
    "constraints": {
      "items": {
        "type": "string"
      },
      "title": "Constraints",
      "type": "array"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "missing_information": {
      "items": {
        "type": "string"
      },
      "title": "Missing Information",
      "type": "array"
    },
    "candidate_options": {
      "items": {
        "$ref": "#/$defs/DecisionOption"
